# Nest realtime service environment example.
# Copy to .env locally or configure in your hosting provider.
# Never commit real secrets.
#
# Local quick-start override:
# NODE_ENV=development
# PORT=4000
# WS_PATH=/ws
# ORIGINS=http://localhost:8081,http://localhost:3000,http://127.0.0.1:8081
# DJANGO_BASE_URL=http://localhost:8000
# DJANGO_API_URL=http://localhost:8000/api/v1
# DJANGO_INTROSPECT_URL=http://localhost:8000/api/v1/chat/auth/introspect/
# DJANGO_CONV_PERMS_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/ws-perms/
# DJANGO_ALLOCATE_SEQ_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/allocate-seq/
# DJANGO_CONV_MEMBER_IDS_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/member-ids/
# DJANGO_CONV_POLICY_CHECK_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/policy-check/
# DJANGO_CONV_UPDATE_LAST_MESSAGE_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/update-last-message/
# DJANGO_CONV_UPDATE_READ_STATE_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/update-read-state/
# DJANGO_CONV_WEBHOOK_DISPATCH_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/webhook-dispatch/
# DJANGO_INTERNAL_TOKEN=dev-internal-token-change-me
# DJANGO_JWT_SECRET=dev-jwt-secret-change-me
# DJANGO_JWT_ISSUER=http://localhost:8000
# DJANGO_JWT_AUDIENCE=messaging-platform
# DJANGO_JWT_STRICT=0
# REDIS_URL=redis://localhost:6379/0
# MONGODB_URI=mongodb://127.0.0.1:27017/kis_chat_local
# MONGODB_DB=kis_chat_local
# UPLOADS_DIR=uploads
# SERVE_UPLOADS_PUBLICLY=1
# PUBLIC_BASE=http://localhost:4000/uploads

PORT=4000
WS_PATH=/ws
NODE_ENV=production
# Production only accepts exact HTTPS origins listed here.
# Local development keeps localhost, 127.0.0.1, and private LAN origins working.
ORIGINS=https://app.example.com,https://admin.example.com

# Django integration (token introspection)
DJANGO_HOST=api.example.com
DJANGO_PORT=8000
DJANGO_BASE_URL=https://api.example.com
DJANGO_API_URL=https://api.example.com/api/v1
DJANGO_INTROSPECT_URL=https://api.example.com/api/v1/chat/auth/introspect/
DJANGO_CONV_PERMS_URL=https://api.example.com/api/v1/chat/conversations/{conversationId}/ws-perms/
DJANGO_ALLOCATE_SEQ_URL=https://api.example.com/api/v1/chat/conversations/{conversationId}/allocate-seq/
DJANGO_INTERNAL_TOKEN=replace-with-strong-shared-internal-token
INTERNAL_SIGNATURE_REQUIRED=1
INTERNAL_SIGNATURE_MAX_SKEW_SECONDS=300
DJANGO_AUTH_SCHEME=Bearer
DJANGO_JWT_SECRET=replace-with-same-strong-jwt-secret-used-by-django
DJANGO_JWT_ISSUER=https://api.example.com
DJANGO_JWT_AUDIENCE=messaging-platform
# REQUIRED in production — rejects tokens without a valid issuer/audience claim.
DJANGO_JWT_STRICT=1
DJANGO_TLS_INSECURE=0

# RS256 migration (recommended — replaces shared HS256 secret).
# When ready: generate an RSA key pair, set Django to sign with the private key,
# set NestJS to verify with the public key only (DJANGO_JWT_PUBLIC_KEY).
# Until then, DJANGO_JWT_SECRET is the shared HS256 signing secret.
# DJANGO_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Redis
REDIS_URL=redis://HOST:6379/0

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/kis
MONGODB_DB=kis

# Uploads
UPLOADS_DIR=uploads
UPLOAD_MAX_BYTES=52428800
# Production defaults to private authenticated upload access. Set this to 1 only
# for a deliberately public media bucket/domain with no private user files.
SERVE_UPLOADS_PUBLICLY=0
PUBLIC_BASE=https://chat.example.com/uploads
# If these are configured, uploads are stored in Supabase S3 instead of Render's local disk.
SUPABASE_S3_ENDPOINT_URL=https://PROJECT_REF.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=replace-with-supabase-s3-access-key
SUPABASE_S3_SECRET_ACCESS_KEY=replace-with-supabase-s3-secret-key
SUPABASE_S3_BUCKET_NAME=kis-uploads
SUPABASE_S3_REGION_NAME=us-east-1
SUPABASE_S3_PUBLIC_URL=https://PROJECT_REF.supabase.co/storage/v1/object/public
# Set to 1 after connecting an antivirus/malware scanning worker.
UPLOAD_SCAN_REQUIRED=0

# Push notifications
FCM_SERVICE_ACCOUNT_PATH=/secure/path/firebase-service-account.json
FCM_SERVICE_ACCOUNT_JSON=

# JWT verification (NestJS-side — must match Django JWT_SECRET/ISSUER/AUDIENCE)
JWT_SECRET=replace-with-same-strong-jwt-secret-used-by-django
JWT_ISSUER=kis
JWT_AUDIENCE=kis-app
# Reject tokens without required claims
JWT_STRICT=true

# Django conversation internal endpoints
DJANGO_CONV_MEMBER_IDS_URL=https://api.example.com/api/v1/chat/conversations/{conversationId}/member-ids/
DJANGO_CONV_POLICY_CHECK_URL=https://api.example.com/api/v1/chat/policy-check/
DJANGO_CONV_UPDATE_LAST_MESSAGE_URL=https://api.example.com/api/v1/chat/update-last-message/
DJANGO_CONV_UPDATE_READ_STATE_URL=https://api.example.com/api/v1/chat/update-read-state/
DJANGO_CONV_WEBHOOK_DISPATCH_URL=https://api.example.com/api/v1/chat/webhook-dispatch/
# Permission cache TTL in milliseconds
DJANGO_CONV_PERMS_TTL_MS=60000

# Video size/duration limits
SHORT_VIDEO_DURATION_SECONDS=60
SHORT_VIDEO_MAX_BYTES=52428800

# Error tracking (optional)
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1
