# .env
PORT=4000
WS_PATH=/ws
ORIGINS=http://localhost:5173,http://localhost:3000

# Django integration (token introspection)
DJANGO_HOST=127.0.0.1
DJANGO_PORT=8000
DJANGO_BASE_URL=http://127.0.0.1:8000
DJANGO_INTROSPECT_URL=http://127.0.0.1:8000/api/v1/chat/auth/introspect/
DJANGO_INTERNAL_TOKEN=dev-internal-secret
DJANGO_AUTH_SCHEME=Bearer
DJANGO_JWT_SECRET=dev-secret
DJANGO_JWT_ISSUER=http://127.0.0.1:8000
DJANGO_JWT_AUDIENCE=messaging-platform
DJANGO_TLS_INSECURE=1

# Redis
REDIS_URL=redis://localhost:6379
