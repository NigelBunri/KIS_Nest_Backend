# Nest realtime service environment example.
# Copy to .env locally or configure in your hosting provider.
# Never commit real secrets.

PORT=4000
WS_PATH=/ws
NODE_ENV=production
# Production only accepts exact HTTPS origins listed here.
# Local development keeps localhost, 127.0.0.1, and private LAN origins working.
ORIGINS=https://app.example.com,https://admin.example.com

# Django integration (token introspection)
DJANGO_HOST=api.example.com
DJANGO_PORT=8000
DJANGO_BASE_URL=https://api.example.com
DJANGO_INTROSPECT_URL=https://api.example.com/api/v1/chat/auth/introspect/
DJANGO_INTERNAL_TOKEN=replace-with-strong-shared-internal-token
INTERNAL_SIGNATURE_REQUIRED=1
INTERNAL_SIGNATURE_MAX_SKEW_SECONDS=300
DJANGO_AUTH_SCHEME=Bearer
DJANGO_JWT_SECRET=replace-with-same-strong-jwt-secret-used-by-django
DJANGO_JWT_ISSUER=https://api.example.com
DJANGO_JWT_AUDIENCE=messaging-platform
DJANGO_JWT_STRICT=1
DJANGO_TLS_INSECURE=0

# Redis
REDIS_URL=redis://HOST:6379/0

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/kis
MONGODB_DB=kis

# Uploads
UPLOADS_DIR=uploads
UPLOAD_MAX_BYTES=52428800
# Production defaults to private authenticated upload access. Set this to 1 only
# for a deliberately public media bucket/domain with no private user files.
SERVE_UPLOADS_PUBLICLY=0
PUBLIC_BASE=https://chat.example.com/uploads
# Set to 1 after connecting an antivirus/malware scanning worker.
UPLOAD_SCAN_REQUIRED=0

# Push notifications
FCM_SERVICE_ACCOUNT_PATH=/secure/path/firebase-service-account.json
FCM_SERVICE_ACCOUNT_JSON=
