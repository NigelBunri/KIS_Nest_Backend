# KIS Nest realtime/chat local environment.
# This file is ignored by git and is only for local testing.
# Render/remote keeps using its configured Environment Variables.

NODE_ENV=development
PORT=4000
WS_PATH=/ws

# Local React Native/Metro/dev origins.
ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://10.0.2.2:8081
ORIGINS_SERVER=http://localhost:8000

# Django local integration.
DJANGO_HOST=http://localhost:8000
DJANGO_BASE_URL=http://localhost:8000
DJANGO_API_URL=http://localhost:8000/api/v1
DJANGO_INTROSPECT_URL=http://localhost:8000/api/v1/chat/auth/introspect/
DJANGO_CONV_PERMS_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/ws-perms/
DJANGO_ALLOCATE_SEQ_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/allocate-seq/
DJANGO_CONV_MEMBER_IDS_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/member-ids/
DJANGO_CONV_POLICY_CHECK_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/policy-check/
DJANGO_CONV_UPDATE_LAST_MESSAGE_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/update-last-message/
DJANGO_CONV_UPDATE_READ_STATE_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/update-read-state/
DJANGO_CONV_WEBHOOK_DISPATCH_URL=http://localhost:8000/api/v1/chat/conversations/{conversationId}/webhook-dispatch/
DJANGO_CONV_PERMS_TTL_MS=120000

# Must match Django .env for local testing.
DJANGO_INTERNAL_TOKEN=local-shared-internal-token-change-me-2026-kis-development-only
DJANGO_AUTH_SCHEME=Bearer
DJANGO_JWT_SECRET=local-shared-jwt-secret-change-me-2026-kis-development-only-keep-out-of-production
DJANGO_JWT_ISSUER=http://localhost:8000
DJANGO_JWT_AUDIENCE=messaging-platform
DJANGO_JWT_STRICT=0
DJANGO_TLS_INSECURE=0

# Local Redis via Homebrew.
REDIS_URL=redis://localhost:6379/0

# Local MongoDB via Homebrew.
MONGODB_URI=mongodb://127.0.0.1:27017/kis_chat_local
MONGODB_DB=kis_chat_local

# Local uploads: use disk, not Supabase/S3.
UPLOADS_DIR=uploads
UPLOAD_MAX_BYTES=2147483647
SERVE_UPLOADS_PUBLICLY=1
PUBLIC_BASE=http://localhost:4000/uploads
SUPABASE_S3_ENDPOINT_URL=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET_NAME=
SUPABASE_S3_REGION_NAME=us-east-1
SUPABASE_S3_PUBLIC_URL=
UPLOAD_SCAN_REQUIRED=0
ATTACHMENT_TTL_DAYS=3650

# Video/media local limits.
SHORT_VIDEO_DURATION_SECONDS=3600
SHORT_VIDEO_MAX_BYTES=2147483647

# Push notifications disabled locally unless explicitly configured.
FCM_SERVICE_ACCOUNT_PATH=
FCM_SERVICE_ACCOUNT_JSON=

# Diagnostics.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
